# Copy to `.env` or `.env.local`.
# Never commit real keys.

# --- Frontend (Vite / Vercel) ---
# Local dev can leave this empty because Vite proxies `/api` to the Node server.
# For Vercel, set this to your Render backend URL, for example:
# VITE_API_BASE_URL=https://atmospark-api.onrender.com
VITE_API_BASE_URL=

# --- Backend (Node / Render) ---
OPENWEATHER_API_KEY=

# Use either GEMINI_API_KEY or GOOGLE_API_KEY.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Optional override if you want a specific Gemini model.
# GEMINI_MODEL=gemini-2.0-flash

# Optional but recommended in production:
# exact frontend origins allowed to call the API, comma-separated
# ALLOWED_ORIGINS=https://atmospark.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=

# API server port (local dev + Render runtime).
PORT=8787

# Optional override for local Vite proxy target only (defaults to PORT).
# VITE_API_PORT=8787

# Optional: only needed if you ever deploy frontend and backend together from the same Node server.
# SERVE_STATIC_FRONTEND=true
