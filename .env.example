# Copy to `.env` or `.env.local` (both are gitignored via *.local / standard practice).
# Never commit real keys.

# --- Vite client (Vercel / static deploy) ---
# These are baked in at build time. Set them in Vercel → Project → Settings → Environment Variables.
VITE_WEATHER_API_KEY=
# OpenRouter bearer token (Vercel name kept as GEMINI for compatibility):
VITE_GEMINI_API_KEY=
# Optional: legacy alias for the same OpenRouter key
# VITE_OPENROUTER_API_KEY=
# Optional OpenRouter model id (default: openai/gpt-3.5-turbo)
# VITE_OPENROUTER_MODEL=

# --- Local Node API server (`server/index.js`) ---
OPENWEATHER_API_KEY=

# Google AI Studio → https://aistudio.google.com/apikey — paste key on ONE line:
#   GEMINI_API_KEY=AIzaSy...your_key...
# No spaces around =. Do not use the VITE_ prefix (the Node server reads this file only).
# If you see "API key not valid": restart after saving .env, and in Google Cloud Console
# open APIs & Services → Credentials → your key → Application restrictions = None (for local dev).
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# If the model 404s, try: gemini-1.5-flash or gemini-2.5-flash-preview-05-20
# GEMINI_MODEL=gemini-2.0-flash

# API server port (dev + production `npm start`). Vite proxies /api → this port.
# If you change PORT, Vite picks it up from this file for the dev proxy.
PORT=8787

# Optional override for the proxy target only (defaults to PORT).
# VITE_API_PORT=8787
